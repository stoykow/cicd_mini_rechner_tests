{
  "name": "mini-rechner-tests",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Ein kleines Testprojekt für Unit-, Integrations- und E2E-Smoke-Tests.",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "test": "node --test tests/unit/rechner.test.js tests/integration/report.test.js tests/e2e/index-smoke.test.js",
    "test:unit": "node --test tests/unit/rechner.test.js",
    "test:integration": "node --test tests/integration/report.test.js",
    "test:e2e": "node --test tests/e2e/index-smoke.test.js",
    "test:coverage": "node --test --experimental-test-coverage tests/unit/rechner.test.js tests/integration/report.test.js",
    "test:report": "node scripts/run-test-report.js"
  }
}
