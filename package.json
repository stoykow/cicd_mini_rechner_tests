{
  "name": "mini-rechner-tests",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Ein kleines Testprojekt für Unit-, Integrations- und E2E-Smoke-Tests.",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "test": "node --test \"tests/**/*.test.js\"",
    "test:unit": "node --test \"tests/unit/**/*.test.js\"",
    "test:integration": "node --test \"tests/integration/**/*.test.js\"",
    "test:e2e": "node --test \"tests/e2e/**/*.test.js\"",
    "test:coverage": "node --test --experimental-test-coverage \"tests/unit/**/*.test.js\" \"tests/integration/**/*.test.js\"",
    "test:report": "node scripts/run-test-report.js"
  }
}
